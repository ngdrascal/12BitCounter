    <visualElement>
      <elementName>Testcase</elementName>
      <elementAttributes>
        <entry>
          <string>Testdata</string>
          <testData>
            <dataString>CLK ~CLR ~LOAD ENT ENP   D C B A Q_D Q_C Q_B Q_A

# load
loop(i,4)
loop(n,16)
C  1   0   bits(2,i) bits(4,n)   bits(4,n)
end loop
end loop

# reset
loop(i,8)
loop(n,16)
C  1   0   0   0     bits(4,n)   bits(4,n)
C  0   bits(3,i)     bits(4,n)   bits(4,0)
end loop
end loop

# count
loop(n,16)
C  1   1   1   1     bits(4,0)   bits(4,n+1)
end loop

# hold
loop(n,16)
C  1   0   0   0     bits(4,n)   bits(4,n)
C  1   1   0   0     bits(4,n)   bits(4,n)
C  1   1   1   0     bits(4,n)   bits(4,n)
C  1   1   0   1     bits(4,n)   bits(4,n)
end loop
</dataString>
          </testData>
        </entry>
